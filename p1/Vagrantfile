Vagrant.configure("2") do |config|
  # ==========================================
  # MAGIA CROSS-PLATFORM (ESCUELA vs MAC M4)
  # ==========================================
  # Determinamos la arquitectura del sistema donde se ejecuta:
  if RUBY_PLATFORM =~ /arm64/ || RUBY_PLATFORM =~ /aarch64/ || (RUBY_PLATFORM =~ /darwin/ && `uname -m`.strip == 'arm64')
    # === MAC APPLE SILICON (Tu M4 Pro) ===
    config.vm.box = "bento/ubuntu-22.04"
    # Vagrant en Mac M-Series usará Parallels o VMware (VirtualBox no existe aquí)
    provider = ENV['VAGRANT_DEFAULT_PROVIDER'] || "vmware_desktop"
  else
    # === ORDENADORES DE 42 (Intel/Linux) ===
    config.vm.box = "bento/ubuntu-22.04"
    provider = "virtualbox"
  end

  # ==========================================
  # CONFIGURACIÓN GLOBAL (Recursos)
  # ==========================================
  config.vm.provider provider do |v|
    if provider == "virtualbox" || provider == "parallels"
      v.memory = 1024
      v.cpus = 1
    elsif provider == "vmware_desktop"
      v.vmx["memsize"] = "1024"
      v.vmx["numvcpus"] = "1"
    end
  end

  # ==========================================
  # MÁQUINA 1: Server (Controller)
  # ==========================================
  config.vm.define "miguelS" do |server|
    server.vm.hostname = "miguelS"
    server.vm.network "private_network", ip: "192.168.56.110"
    
    server.vm.provider provider do |v|
      if provider == "virtualbox" || provider == "parallels"
        v.name = "miguelS"
      elsif provider == "vmware_desktop"
        v.vmx["displayname"] = "miguelS"
      end
    end
    
    # Ejecutamos el script cuando se crea la máquina
    server.vm.provision "shell", path: "scripts/server.sh", args: "192.168.56.110"
  end

  # ==========================================
  # MÁQUINA 2: Worker (Agent)
  # ==========================================
  config.vm.define "miguelSW" do |worker|
    worker.vm.hostname = "miguelSW"
    worker.vm.network "private_network", ip: "192.168.56.111"

    worker.vm.provider provider do |v|
      if provider == "virtualbox" || provider == "parallels"
        v.name = "miguelSW"
      elsif provider == "vmware_desktop"
        v.vmx["displayname"] = "miguelSW"
      end
    end
    
    # Ejecutamos el script del worker, pasándole la IP del jefe y la suya propia
    worker.vm.provision "shell", path: "scripts/worker.sh", args: "192.168.56.110 192.168.56.111"
  end
end
